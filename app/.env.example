# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Meta (Instagram / WhatsApp)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-meta-verify-token
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Calendly
CALENDLY_ACCESS_TOKEN=your-calendly-access-token
CALENDLY_WEBHOOK_SIGNING_KEY=your-calendly-webhook-signing-key
CALENDLY_ORGANIZATION_URI=https://api.calendly.com/organizations/xxxx

# Resend / Email
RESEND_API_KEY=re_xxx
EMAIL_FROM=ops@yourdomain.com
EMAIL_REPLY_TO=soporte@yourdomain.com

# Slack
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_DEFAULT_CHANNEL=#ops-alertas

# AI Provider
AI_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
AI_MODEL_DEFAULT=gpt-4.1-mini

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-default-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Health endpoints (optional)
# If set, /api/health/config and /api/health/go-live require header: x-health-token: <value>
HEALTH_ENDPOINT_TOKEN=your-random-long-token

# Cron worker tick (required for go-live reliability)
# Protects POST /api/cron/worker-tick
CRON_JOB_TOKEN=your-random-long-token

# Go-live guardrails
# WARNING: Several subsystems still persist in-memory (worker jobs, webhook retry queue, snapshots).
# In production this is risky; /api/health/go-live will fail unless you explicitly acknowledge it.
ALLOW_IN_MEMORY_PERSISTENCE=false

# Go-live smoke (optional)
# If set, `npm run smoke:go-live` will call the deployed endpoint instead of local checks.
APP_URL=https://your-deployed-domain.com
